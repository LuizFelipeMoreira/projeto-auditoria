generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  role            ROLE             @default(FUNCIONARIO)
  lojaId          Int
  financeRequests FinanceRequest[] @relation("UserRequest")
  loja            Store            @relation(fields: [lojaId], references: [id])

  @@index([lojaId], map: "User_lojaId_fkey")
}

model Store {
  id               Int              @id @default(autoincrement())
  name             String
  financesRequests FinanceRequest[]
  users            User[]
}

model FinanceRequest {
  id          Int      @id @default(autoincrement())
  description String
  createdAt   DateTime @default(now())
  value       Float
  status      STATUS   @default(AGUARDANDO)
  solicitante Int
  lojaId      Int
  loja        Store    @relation(fields: [lojaId], references: [id])
  user        User     @relation("UserRequest", fields: [solicitante], references: [id])

  @@index([lojaId], map: "FinanceRequest_lojaId_fkey")
  @@index([solicitante], map: "FinanceRequest_solicitante_fkey")
}

enum ROLE {
  ADMIN
  FUNCIONARIO
}

enum STATUS {
  APROVADO
  AGUARDANDO
  REPROVADO
}
